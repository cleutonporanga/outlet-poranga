
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Representa um item de vestuário no estoque da outlet.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sku": { "type": "string", "description": "Código interno ou SKU do produto" },
        "name": { "type": "string" },
        "brand": { "type": "string", "description": "Marca do produto" },
        "category": { "type": "string" },
        "size": { "type": "string" },
        "color": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "category", "quantity", "price", "costPrice"]
    },
    "Movement": {
      "title": "Movement",
      "description": "Registro de uma venda realizada.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["entrada", "saída"] },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "unitCost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "type", "quantity", "date"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Produtos do inventário privado do usuário."
    },
    "/users/{userId}/movements/{movementId}": {
      "schema": { "$ref": "#/backend/entities/Movement" },
      "description": "Histórico de vendas e lucros do usuário."
    }
  }
}
